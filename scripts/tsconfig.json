{
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["@types/node"],
    "esModuleInterop": true
  },
  "include": ["./"],
  "exclude": ["node_modules"]
}
